# ── Authentication ─────────────────────────────────────────────────────────────
# Random 32+ character secret for JWT signing
JWT_SECRET=

# bcryptjs hash of your login password. Generate with:
#   node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
FIDUCIARY_PASSWORD_HASH=

# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Plaid ──────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox
# 32-byte hex key for AES-256-GCM token encryption. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_TOKEN_ENCRYPTION_KEY=

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Python Backend ─────────────────────────────────────────────────────────────
# URL of the FastAPI backend (uvicorn backend.main:app --port 8000)
FIDUCIARY_PYTHON_API_URL=http://localhost:8000

# ── Vercel Cron ────────────────────────────────────────────────────────────────
# Set this in Vercel dashboard; include as Bearer token in cron requests
CRON_SECRET=

# ── CORS (optional) ────────────────────────────────────────────────────────────
# Additional origin to allow on the Python backend (e.g. your Vercel preview URL)
ALLOWED_ORIGIN=
